# Project
PROJECT_NAME=MediOps Cloud Platform
ENV=local

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0
JWT_SECRET=change-me-local-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=mediops
POSTGRES_PASSWORD=mediops_password
POSTGRES_DB=mediops
DATABASE_URL=postgresql://mediops:mediops_password@postgres:5432/mediops

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin